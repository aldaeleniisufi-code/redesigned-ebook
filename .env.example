# Postgres connection string (Vercel Postgres / Neon / Supabase / Railway κ.λπ.)
# Τοπικά για development χρειάζεσαι τρέχον Postgres (π.χ. Docker) ή να δείξεις
# κατευθείαν σε ένα development/production Postgres που ήδη υπάρχει.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Δημιούργησε μια τιμή με: openssl rand -base64 32
# ΣΗΜΑΝΤΙΚΟ: χρησιμοποίησε διαφορετική τιμή στο production απ' ό,τι τοπικά.
AUTH_SECRET="replace-me"

# Στο production βάλε το πραγματικό domain (π.χ. https://mysite.vercel.app)
APP_URL="http://localhost:3000"

# Stripe: test keys για ανάπτυξη (dashboard.stripe.com/test/apikeys),
# live keys (sk_live_...) μόνο στο production όταν είσαι έτοιμος να δέχεσαι
# πραγματικές πληρωμές.
STRIPE_SECRET_KEY="sk_test_..."
# Προαιρετικό (μόνο για το webhook σε /api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET="whsec_..."

# Vercel Blob storage για uploaded εικόνες βιβλίων.
# Χωρίς αυτό, οι εικόνες αποθηκεύονται τοπικά σε public/uploads (λειτουργεί
# μόνο σε περιβάλλον με persistent δίσκο, όχι σε serverless όπως το Vercel).
# Δημιουργείται αυτόματα όταν συνδέσεις ένα Blob store στο Vercel project.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Resend (resend.com) — αποστολή email επιβεβαίωσης εγγραφής & απόδειξης αγοράς.
# Χρειάζεται verified domain στο Resend dashboard (Domains -> Add Domain) πριν
# μπορέσεις να στείλεις πραγματικά emails. Χωρίς αυτό, η αποστολή απλά αποτυγχάνει
# σιωπηλά (δεν μπλοκάρει εγγραφή/αγορά).
RESEND_API_KEY="re_..."
